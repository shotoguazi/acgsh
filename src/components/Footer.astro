---

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-bg"></div>
  <div class="footer-inner">
    <div class="footer-links">
      <a href="https://www.acgsh.com/" target="_blank">首页</a>
      <span class="dot">·</span>
      <a href="https://www.acgsh.com/about/" target="_blank">关于我们</a>
      <span class="dot">·</span>
      <a href="https://cnb.cool/acgsh/astro_website" target="_blank" rel="noopener">CNB</a>
    </div>
    <p class="footer-license">
      <a href="https://creativecommons.org/licenses/by-nc-nd/4.0/deed.zh-hans" target="_blank" rel="noopener">
        CC BY-NC-ND 4.0
      </a>
    </p>
    <p class="footer-copy">Copyright © 2023-{year} 魔都ACGN活动交流群 - 管理组</p>
    <p class="footer-powered">
      <a href="https://beian.miit.gov.cn/" target="_blank" rel="noopener">皖ICP备2026016891号</a>
      Powered by <a href="https://astro.build" target="_blank" rel="noopener">Astro</a>
      问题反馈 <a href="mailto:guazi@acgsh.com" target="_blank" rel="noopener">guazi@acgsh.com</a>
      由 <a href="https://www.aliyun.com/product/esa" target="_blank" rel="noopener">阿里云ESA</a> 提供防护支持
    </p>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    overflow: hidden;
    padding: 40px 20px 30px;
    text-align: center;
    margin-top: 80px;
    border-top: 1px solid var(--line);
  }

  .footer-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent, rgba(var(--brand-rgb),.03) 40%, rgba(var(--brand2-rgb),.03));
    pointer-events: none;
  }

  .footer-inner {
    position: relative;
    max-width: 1400px;
    margin: 0 auto;
  }

  .footer-links {
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .footer-links a {
    color: var(--muted);
    font-size: 14px;
    transition: color .2s;
  }

  .footer-links a:hover {
    color: var(--brand);
    text-decoration: none;
  }

  .dot {
    color: var(--line);
    font-size: 12px;
  }

  .footer-license a {
    color: var(--muted);
    font-size: 12px;
    border: 1px solid var(--line);
    padding: 3px 10px;
    border-radius: 999px;
    transition: all .2s;
  }

  .footer-license a:hover {
    border-color: var(--brand);
    color: var(--brand);
    text-decoration: none;
  }

  .footer-copy {
    color: var(--muted);
    font-size: var(--small);
    margin-top: 12px;
  }

  .footer-powered {
    margin-top: 10px;
    font-size: 12px;
    color: var(--muted);
  }

  .footer-powered a {
    color: var(--brand2);
  }
</style>
