---
const navItems = [
  { text: '首页', link: '/' },
  {
    text: '展览',
    children: [
      { text: 'BW快速指南', link: '/guide/exhibit/BilibiliWorldBasicInfo/' },
      { text: 'ChinaJoy', link: '/guide/exhibit/ChinaJoyBasicInfo/' },
    ],
  },
  {
    text: '演唱会',
    children: [
      { text: 'BML快速指南', link: '/guide/concert/BilibiliMacroLinkBasicInfo/' },
    ],
  },
  {
    text: '介绍',
    children: [
      { text: 'BML是什么', link: '/guide/intro/BilibiliMacroLinkIntro/' },
    ]
  },
  {
    text: '其它',
    children: [
      { text: '上海未来活动一览', link: '/guide/others/OverviewOfShanghaiFutureACGNActivities/' },
      { text: '出国带卡指南', link: '/guide/others/card/' },
      { text: '上海游物推荐', link: '/guide/others/ShanghaiTravelGuide_Anime/' },
      { text: '闪击日本攻略', link: '/guide/others/JP2025/' },
    ],
  },
];
---

<nav class="navbar">
  <div class="nav-inner">
    <a href="/" class="nav-logo">魔都ACGN活动交流群 - 资讯站</a>

    <div class="nav-right">
    <button class="nav-toggle" aria-label="菜单" id="nav-toggle">
      <span></span>
      <span></span>
      <span></span>
      <span></span>
    </button>
    <ul class="nav-menu" id="nav-menu">
      {navItems.map((item) => (
        <li class={`nav-item ${item.children ? 'has-dropdown' : ''}`}>
          {item.children ? (
            <>
              <span class="nav-link">{item.text}</span>
              <ul class="dropdown">
                {item.children.map((child) => (
                  <li>
                    <a href={child.link}>{child.text}</a>
                  </li>
                ))}
              </ul>
            </>
          ) : (
            <a href={item.link} class="nav-link">{item.text}</a>
          )}
        </li>
      ))}
    </ul>

    <button class="theme-toggle" id="theme-toggle" aria-label="切换主题">
      <svg class="sun-icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="5"/>
        <line x1="12" y1="1" x2="12" y2="3"/>
        <line x1="12" y1="21" x2="12" y2="23"/>
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
        <line x1="1" y1="12" x2="3" y2="12"/>
        <line x1="21" y1="12" x2="23" y2="12"/>
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
      </svg>
      <svg class="moon-icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
      </svg>
    </button>
    </div>
  </div>
</nav>

<style>
  .navbar {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--glass-nav-bg);
    backdrop-filter: blur(20px) saturate(1.5);
    -webkit-backdrop-filter: blur(20px) saturate(1.5);
    border-bottom: 1px solid var(--glass-nav-border);
    box-shadow: var(--shadow-nav);
  }

  .nav-inner {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: var(--nav-height);
    padding: 0 20px;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 2px;
  }

  .nav-logo {
    font-weight: 800;
    font-size: 1.35em;
    font-family: "Microsoft YaHei UI", "Microsoft YaHei", "PingFang SC", sans-serif;
    background: linear-gradient(135deg, var(--brand), var(--brand2));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: .5px;
    transition: opacity .2s;
  }

  .nav-logo:hover {
    opacity: .7;
    text-decoration: none;
  }

  .nav-menu {
    display: flex;
    align-items: center;
    list-style: none;
    gap: 2px;
    margin: 0;
    padding: 0;
  }

  .nav-item {
    position: relative;
  }

  .nav-link {
    display: block;
    padding: 8px 14px;
    border-radius: 8px;
    color: var(--text);
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition: all .25s ease;
    position: relative;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    left: 14px;
    right: 14px;
    bottom: 4px;
    height: 2px;
    border-radius: 2px;
    background: linear-gradient(135deg, var(--brand), var(--brand2));
    transform: scaleX(0);
    transition: transform .25s ease;
  }

  .nav-link:hover::after,
  .has-dropdown:hover > .nav-link::after {
    transform: scaleX(1);
  }

  .nav-link:hover,
  .has-dropdown:hover > .nav-link {
    background: linear-gradient(135deg, rgba(var(--brand-rgb), .08), rgba(var(--brand2-rgb), .08));
    text-decoration: none;
  }

  .dropdown {
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    min-width: 190px;
    list-style: none;
    padding: 8px;
    margin: 0;
    border-radius: 12px;
    background: var(--glass-dropdown-bg);
    backdrop-filter: blur(16px) saturate(1.4);
    -webkit-backdrop-filter: blur(16px) saturate(1.4);
    border: 1px solid var(--glass-dropdown-border);
    box-shadow: var(--shadow-dropdown);
    opacity: 0;
    visibility: hidden;
    transform: translateY(8px);
    transition: opacity .2s ease, transform .2s ease, visibility .2s ease;
    z-index: 200;
  }

  .has-dropdown:hover > .dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .dropdown a {
    display: block;
    padding: 8px 14px;
    border-radius: 8px;
    color: var(--text);
    font-size: 14px;
    white-space: nowrap;
    transition: all .2s ease;
  }

  .dropdown a:hover {
    background: linear-gradient(135deg, rgba(var(--brand-rgb), .1), rgba(var(--brand2-rgb), .1));
    padding-left: 18px;
    text-decoration: none;
  }

  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: 1px solid var(--line);
    border-radius: 8px;
    color: var(--muted);
    cursor: pointer;
    padding: 6px;
    width: 32px;
    height: 32px;
    transition: all .2s;
    margin-right: 2px;
  }

  .theme-toggle:hover {
    color: var(--text);
    background: rgba(var(--brand-rgb), .08);
    border-color: transparent;
  }

  :root.dark .sun-icon { display: block; }
  :root.dark .moon-icon { display: none; }
  :root:not(.dark) .sun-icon { display: none; }
  :root:not(.dark) .moon-icon { display: block; }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .nav-toggle span {
    width: 24px;
    height: 2px;
    background: var(--text);
    border-radius: 2px;
    transition: .3s;
  }

  @media (max-width: 768px) {
    .nav-toggle {
      display: flex;
    }

    .nav-logo {
      font-size: 1.05em;
    }

    .nav-menu {
      display: none;
      position: absolute;
      top: var(--nav-height);
      left: 0;
      right: 0;
      background: var(--card);
      border-bottom: var(--border);
      flex-direction: column;
      align-items: stretch;
      padding: 10px;
    }

    .nav-menu.open {
      display: flex;
    }

    .nav-item {
      width: 100%;
    }

    .nav-link {
      width: 100%;
    }

    .dropdown {
      position: static;
      opacity: 1;
      visibility: visible;
      transform: none;
      display: none;
      box-shadow: none;
      border: none;
      background: transparent;
      padding: 4px 0 4px 14px;
      margin: 0;
    }

    .has-dropdown:hover > .dropdown {
      display: block;
    }
  }
</style>

<script>
  const navToggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('nav-menu');

  if (navToggle && menu) {
    navToggle.addEventListener('click', () => {
      menu.classList.toggle('open');
    });
  }

  const themeToggle = document.getElementById('theme-toggle');
  if (themeToggle) {
    themeToggle.addEventListener('click', () => {
      const isDark = document.documentElement.classList.toggle('dark');
      document.documentElement.classList.toggle('light', !isDark);
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
    });
  }
</script>