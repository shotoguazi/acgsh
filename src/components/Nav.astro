---
const navItems = [
  { text: '首页', link: '/' },
  {
    text: '展览',
    children: [
      { text: 'BW快速指南', link: '/guide/exhibit/BilibiliWorldBasicInfo/' },
      { text: 'ChinaJoy', link: '/guide/exhibit/ChinaJoyBasicInfo/' },
    ],
  },
  {
    text: '演唱会',
    children: [
      { text: 'BML快速指南', link: '/guide/concert/BilibiliMacroLinkBasicInfo/' },
    ],
  },
  {
    text: '介绍',
    children: [
      { text: 'BML是什么', link: '/guide/intro/BilibiliMacroLinkIntro/' },
    ]
  },
  {
    text: '其它',
    children: [
      { text: '上海未来活动一览', link: '/guide/others/OverviewOfShanghaiFutureACGNActivities/' },
      { text: '出国带卡指南', link: '/guide/others/card/' },
      { text: '上海游物推荐', link: '/guide/others/ShanghaiTravelGuide_Anime/' },
      { text: '闪击日本攻略', link: '/guide/others/JP2025/' },
    ],
  },
];
---

<nav class="navbar">
  <div class="nav-inner">
    <a href="/" class="nav-logo">魔都ACGN活动交流群 - 资讯站</a>

    <button class="nav-toggle" aria-label="菜单" id="nav-toggle">
      <span></span>
      <span></span>
      <span></span>
      <span></span>
    </button>

    <ul class="nav-menu" id="nav-menu">
      {navItems.map((item) => (
        <li class={`nav-item ${item.children ? 'has-dropdown' : ''}`}>
          {item.children ? (
            <>
              <span class="nav-link">{item.text}</span>
              <ul class="dropdown">
                {item.children.map((child) => (
                  <li>
                    <a href={child.link}>{child.text}</a>
                  </li>
                ))}
              </ul>
            </>
          ) : (
            <a href={item.link} class="nav-link">{item.text}</a>
          )}
        </li>
      ))}
    </ul>
  </div>
</nav>

<style>
  .navbar {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, .72);
    backdrop-filter: blur(20px) saturate(1.5);
    -webkit-backdrop-filter: blur(20px) saturate(1.5);
    border-bottom: 1px solid rgba(255, 255, 255, .4);
    box-shadow: 0 1px 12px rgba(0, 0, 0, .06);
  }

  @media (prefers-color-scheme: dark) {
    .navbar {
      background: rgba(15, 23, 48, .72);
      border-bottom: 1px solid rgba(255, 255, 255, .08);
    }
  }

  .nav-inner {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: var(--nav-height);
    padding: 0 20px;
  }

  .nav-logo {
    font-weight: 800;
    font-size: 1.35em;
    font-family: "Microsoft YaHei UI", "Microsoft YaHei", "PingFang SC", sans-serif;
    background: linear-gradient(135deg, var(--brand), var(--brand2));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: .5px;
    transition: opacity .2s;
  }

  .nav-logo:hover {
    opacity: .7;
    text-decoration: none;
  }

  .nav-menu {
    display: flex;
    align-items: center;
    list-style: none;
    gap: 2px;
    margin: 0;
    padding: 0;
  }

  .nav-item {
    position: relative;
  }

  .nav-link {
    display: block;
    padding: 8px 14px;
    border-radius: 8px;
    color: var(--text);
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition: all .25s ease;
    position: relative;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    left: 14px;
    right: 14px;
    bottom: 4px;
    height: 2px;
    border-radius: 2px;
    background: linear-gradient(135deg, var(--brand), var(--brand2));
    transform: scaleX(0);
    transition: transform .25s ease;
  }

  .nav-link:hover::after,
  .has-dropdown:hover > .nav-link::after {
    transform: scaleX(1);
  }

  .nav-link:hover,
  .has-dropdown:hover > .nav-link {
    background: linear-gradient(135deg, rgba(255, 105, 180, .08), rgba(91, 124, 255, .08));
    text-decoration: none;
  }

  .dropdown {
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    min-width: 190px;
    list-style: none;
    padding: 8px;
    margin: 0;
    border-radius: 12px;
    background: rgba(255, 255, 255, .8);
    backdrop-filter: blur(16px) saturate(1.4);
    -webkit-backdrop-filter: blur(16px) saturate(1.4);
    border: 1px solid rgba(255, 255, 255, .6);
    box-shadow: 0 8px 32px rgba(20, 116, 158, .12);
    opacity: 0;
    visibility: hidden;
    transform: translateY(8px);
    transition: opacity .2s ease, transform .2s ease, visibility .2s ease;
    z-index: 200;
  }

  @media (prefers-color-scheme: dark) {
    .dropdown {
      background: rgba(15, 23, 48, .88);
      border: 1px solid rgba(255, 255, 255, .1);
      box-shadow: 0 8px 32px rgba(0, 0, 0, .3);
    }
  }

  .has-dropdown:hover > .dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .dropdown a {
    display: block;
    padding: 8px 14px;
    border-radius: 8px;
    color: var(--text);
    font-size: 14px;
    white-space: nowrap;
    transition: all .2s ease;
  }

  .dropdown a:hover {
    background: linear-gradient(135deg, rgba(255, 105, 180, .1), rgba(91, 124, 255, .1));
    padding-left: 18px;
    text-decoration: none;
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .nav-toggle span {
    width: 24px;
    height: 2px;
    background: var(--text);
    border-radius: 2px;
    transition: .3s;
  }

  @media (max-width: 768px) {
    .nav-toggle {
      display: flex;
    }

    .nav-logo {
      font-size: 1.05em;
    }

    .nav-menu {
      display: none;
      position: absolute;
      top: var(--nav-height);
      left: 0;
      right: 0;
      background: var(--card);
      border-bottom: var(--border);
      flex-direction: column;
      align-items: stretch;
      padding: 10px;
    }

    .nav-menu.open {
      display: flex;
    }

    .nav-item {
      width: 100%;
    }

    .nav-link {
      width: 100%;
    }

    .dropdown {
      position: static;
      opacity: 1;
      visibility: visible;
      transform: none;
      display: none;
      box-shadow: none;
      border: none;
      background: transparent;
      padding: 4px 0 4px 14px;
      margin: 0;
    }

    .has-dropdown:hover > .dropdown {
      display: block;
    }
  }
</style>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('nav-menu');

  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      menu.classList.toggle('open');
    });
  }
</script>