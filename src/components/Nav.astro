---
const navItems = [
  { text: '首页', link: '/' },
  {
    text: '展览',
    children: [
      { text: 'BW快速指南', link: '/guide/exhibit/BilibiliWorldBasicInfo/' },
      { text: 'BW2026最新消息', link: '/guide/exhibit/BiliBiliWorld2026/' },
      { text: 'ChinaJoy', link: '/guide/exhibit/ChinaJoyBasicInfo/' },
    ],
  },
  {
    text: '演唱会',
    children: [
      { text: 'BML快速指南', link: '/guide/concert/BilibiliMacroLinkBasicInfo/' },
      { text: 'トゲナシトゲアリ Live', link: '/guide/concert/GirlsBandCryInfo/' },
    ],
  },
  {
    text: '其它',
    children: [
      { text: '上海未来活动一览', link: '/guide/others/OverviewOfShanghaiFutureACGNActivities/' },
      { text: '出国带卡指南', link: '/guide/others/card/' },
      { text: '上海游物推荐', link: '/guide/others/ShanghaiTravelGuide_Anime/' },
      { text: '闪击日本攻略', link: '/guide/others/JP2025/' },
      { text: '评论区', link: '/guide/Comment/' },
    ],
  },
];
---

<nav class="navbar">
  <div class="nav-inner">
    <a href="/" class="nav-logo">魔都ACGN活动交流群 - 资讯站</a>
    <button class="nav-toggle" aria-label="菜单" id="nav-toggle">
      <span></span><span></span><span></span>
    </button>
    <ul class="nav-menu" id="nav-menu">
      {navItems.map((item) => (
        <li class="nav-item {item.children ? 'has-dropdown' : ''}">
          {item.children ? (
            <>
              <span class="nav-link">{item.text}</span>
              <ul class="dropdown">
                {item.children.map((child) => (
                  <li><a href={child.link}>{child.text}</a></li>
                ))}
              </ul>
            </>
          ) : (
            <a href={item.link} class="nav-link">{item.text}</a>
          )}
        </li>
      ))}
    </ul>
  </div>
</nav>

  <style>
    .navbar {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(255, 255, 255, .8);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-bottom: 1px solid rgba(20, 32, 60, .06);
      box-shadow: 0 1px 8px rgba(0,0,0,.04);
    }

    @media (prefers-color-scheme: dark) {
      .navbar {
        background: rgba(15, 23, 48, .8);
        border-bottom: 1px solid rgba(255,255,255,.06);
      }
    }

    .nav-inner {
      max-width: 1400px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: var(--nav-height);
      padding: 0 20px;
    }

    .nav-logo {
      font-weight: 400;
      font-size: 1.15em;
      color: #000;
      letter-spacing: .5px;
      transition: opacity .2s;
    }

    @media (prefers-color-scheme: dark) {
      .nav-logo {
        color: #fff;
      }
    }

    .nav-logo:hover {
      opacity: .8;
      text-decoration: none;
    }

    .nav-menu {
      display: flex;
      list-style: none;
      gap: 2px;
    }

    .nav-link {
      display: block;
      padding: 8px 14px;
      border-radius: 8px;
      color: var(--text);
      font-size: 14px;
      font-weight: 500;
      cursor: pointer;
      transition: all .25s ease;
      position: relative;
    }

    .nav-link:hover {
      background: linear-gradient(135deg, rgba(255,105,180,.08), rgba(91,124,255,.08));
      text-decoration: none;
    }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .nav-toggle span {
    width: 24px;
    height: 2px;
    background: var(--text);
    border-radius: 2px;
    transition: .3s;
  }

  @media (max-width: 768px) {
    .nav-menu {
      display: none;
      position: absolute;
      top: var(--nav-height);
      left: 0;
      right: 0;
      background: var(--card);
      border-bottom: var(--border);
      flex-direction: column;
      padding: 10px;
    }

    .nav-menu.open {
      display: flex;
    }

    .nav-toggle {
      display: flex;
    }
  }
</style>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('nav-menu');
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      menu.classList.toggle('open');
    });
  }

  document.querySelectorAll('.has-dropdown').forEach(li => {
    li.addEventListener('mouseenter', () => {
      const dd = li.querySelector('.dropdown');
      if (dd) dd.style.display = 'block';
    });
    li.addEventListener('mouseleave', () => {
      const dd = li.querySelector('.dropdown');
      if (dd) dd.style.display = '';
    });
  });
</script>

<style is:global>
  .has-dropdown { position: relative; }
  .dropdown {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    background: var(--card);
    border: var(--border);
    border-radius: 12px;
    padding: 6px;
    min-width: 180px;
    box-shadow: var(--shadow);
    list-style: none;
    z-index: 200;
  }
  .dropdown li a {
    display: block;
    padding: 8px 14px;
    border-radius: 8px;
    color: var(--text);
    font-size: 14px;
    white-space: nowrap;
  }
  .dropdown li a:hover {
    background: rgba(91, 124, 255, .1);
    text-decoration: none;
  }
  @media (max-width: 768px) {
    .dropdown {
      position: static !important;
      box-shadow: none !important;
      border: none !important;
      display: none !important;
    }
  }
</style>
