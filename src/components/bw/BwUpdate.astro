---
export interface Props {
  theme?: 'green' | 'red' | 'yellow' | 'blue' | 'purple' | 'gray';
}

const { theme = 'green' } = Astro.props;
---

<div class={`bw-update bw-theme bw-${theme}`}>
  <slot name="latest" />
  <slot name="history" />
</div>

<style>
  .bw-update {
    border: var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    margin: 10px 0;
    background: var(--card);
  }
  .bw-green  { --theme-color: #22c55e; }
  .bw-red    { --theme-color: #ef4444; }
  .bw-yellow { --theme-color: #eab308; }
  .bw-blue   { --theme-color: #3b82f6; }
  .bw-purple { --theme-color: #a855f7; }
  .bw-gray   { --theme-color: #6b7280; }
</style>
