---
export interface Props {
  id?: string;
}
---

<div class="bw-section" id={Astro.props.id}>
  <slot />
</div>

<style>
  .bw-section {
    margin-top: 18px;
    background: var(--card);
    border: var(--border);
    border-radius: var(--radius);
    padding: var(--pad);
    box-shadow: var(--shadow);
  }

  .bw-section :global(h2) {
    margin: 0 0 10px;
    font-size: var(--h2);
    display: flex;
    align-items: center;
    gap: 10px;
  }
</style>
