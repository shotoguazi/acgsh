---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;

const sidebarLinks = [
  { text: '首页', link: '/' },
  { text: 'BW快速指南', link: '/guide/exhibit/BilibiliWorldBasicInfo/' },
  { text: 'BML快速指南', link: '/guide/concert/BilibiliMacroLinkBasicInfo/' },
  { text: 'ChinaJoy', link: '/guide/exhibit/ChinaJoyBasicInfo/' },
  { text: '关于BML', link: '/guide/intro/BilibiliMacroLinkIntro/' },
  { text: '上海未来活动', link: '/guide/others/OverviewOfShanghaiFutureACGNActivities/' },
  { text: '上海游物推荐', link: '/guide/others/ShanghaiTravelGuide_Anime/' },
];

const currentPath = Astro.url.pathname;
---

<BaseLayout title={title} description={description}>
  <div class="guide-layout">
    <aside class="guide-sidebar">
      <nav>
        {sidebarLinks.map(item => (
          <a href={item.link} class:list={{ active: currentPath === item.link }}>{item.text}</a>
        ))}
      </nav>
    </aside>
    <article class="guide-content">
      <slot />
    </article>
  </div>
</BaseLayout>

<style>
  .guide-layout {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    gap: 30px;
    padding: 20px 20px 0;
    min-height: calc(100vh - var(--nav-height));
  }

  .guide-sidebar {
    width: 190px;
    flex-shrink: 0;
    position: sticky;
    top: calc(var(--nav-height) + 20px);
    align-self: flex-start;
    max-height: calc(100vh - var(--nav-height) - 40px);
    overflow-y: auto;
    padding: 0 0 20px;
  }

  .guide-sidebar nav {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .guide-sidebar a {
    display: block;
    padding: 6px 12px;
    border-radius: 6px;
    font-size: 14px;
    color: var(--muted);
    text-decoration: none;
    transition: background .15s, color .15s;
  }

  .guide-sidebar a:hover {
    background: rgba(var(--brand2-rgb),.1);
    color: var(--text);
    text-decoration: none;
  }

  .guide-sidebar a.active {
    background: rgba(var(--brand2-rgb),.12);
    color: var(--brand2);
    font-weight: 600;
  }

  .guide-content {
    flex: 1;
    min-width: 0;
    padding: 0 0 60px;
  }

  .guide-content h1 {
    font-size: var(--h1);
    margin-bottom: 12px;
  }

  .guide-content h2 {
    font-size: var(--h2);
    margin: 24px 0 10px;
  }

  .guide-content h3 {
    font-size: 1.1em;
    margin: 18px 0 8px;
  }

  .guide-content p {
    margin: 8px 0;
    line-height: 1.75;
  }

  .guide-content ul, .guide-content ol {
    margin: 8px 0;
    padding: 0;
    list-style: none;
  }

  .guide-content li {
    margin: 4px 0;
    padding-left: 1.2em;
    position: relative;
  }

  .guide-content li::before {
    content: "•";
    position: absolute;
    left: 0.3em;
    color: var(--muted);
  }

  .guide-content :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: var(--radius);
    margin: 10px 0;
    display: block;
  }

  @media (max-width: 768px) {
    .guide-layout {
      flex-direction: column;
      padding: 0 14px;
    }
    .guide-sidebar {
      display: none;
    }
  }
</style>
