---
import '@/styles/global.css';
const year = new Date().getFullYear();
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>关于我们 - ACGSH</title>
  <meta name="description" content="魔都ACGN活动交流群附属网站" />
  <link rel="icon" type="image/png" href="/favicon.png" />
</head>
<body>
  <div class="page">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="grid"></div>

    <div class="page-content">
      <a href="/" class="back-link">← 返回首页</a>
      <h1 class="page-title">关于我们</h1>
      <p class="page-subtitle">魔都ACGN活动交流群 · 管理组</p>

      <div class="intro">
        <p>魔都ACGN活动交流群成立于2023年，是一个由ACGN爱好者组成的线下活动QQ交流群。我们致力于汇聚全网ACGN活动资源，打造魔都最全的ACGN活动信息平台。</p>
        <p>从BW/BML到ChinaJoy，从演唱会到主题展览，我们为群友提供第一手活动资讯和购票指南。</p>
        <p>管理组成员来自于各群的活跃群友，我们会不定期新增成员！</p>
      </div>

      <div class="disclaimer">此处头像来自各成员QQ，与本站无关</div>

      
    </div>

    <div class="footer-text">
      <a href="https://beian.miit.gov.cn/" target="_blank" rel="noopener">皖ICP备2026016891号</a>
      <span class="sep">|</span>
      <span>Copyright © 2023-{year} 是瓜子酱 & 魔都ACGN活动交流群</span>
    </div>
  </div>
</body>
</html>

<style>
  .page {
    min-height: 100vh;
    position: relative;
    overflow-x: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 40px 20px;
    background: var(--bg);
    color: var(--text);
  }

  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
  }

  .orb-1 {
    width: 400px;
    height: 400px;
    background: rgba(var(--brand-rgb), .08);
    top: -10%;
    right: -10%;
  }

  .orb-2 {
    width: 350px;
    height: 350px;
    background: rgba(var(--brand2-rgb), .06);
    bottom: -10%;
    left: -10%;
  }

  .grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(var(--black-rgb), .03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(var(--black-rgb), .03) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
  }

  :root.dark .orb-1 { background: rgba(var(--brand-rgb), .1); }
  :root.dark .orb-2 { background: rgba(var(--brand2-rgb), .08); }
  :root.dark .grid {
    background-image:
      linear-gradient(rgba(255,255,255,.015) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,.015) 1px, transparent 1px);
  }

  .page-content {
    position: relative;
    z-index: 1;
    max-width: 800px;
    width: 100%;
    animation: fadeUp .8s ease-out;
  }

  @keyframes fadeUp {
    0% { opacity: 0; transform: translateY(30px); }
    100% { opacity: 1; transform: translateY(0); }
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--muted);
    font-size: 14px;
    margin-bottom: 30px;
    transition: color .2s;
  }

  .back-link:hover { color: var(--text); text-decoration: none; }

  .page-title {
    font-size: 2.5em;
    font-weight: 800;
    background: linear-gradient(135deg, var(--brand), var(--brand2));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 4px;
  }

  .page-subtitle {
    color: var(--muted);
    font-size: 14px;
    letter-spacing: 3px;
    margin-bottom: 30px;
  }

  .intro {
    background: var(--card);
    border: var(--border);
    border-radius: var(--radius);
    padding: 20px 24px;
    margin-bottom: 40px;
  }

  .intro p {
    color: var(--muted);
    font-size: 15px;
    line-height: 1.8;
    margin: 6px 0;
  }

  .section-title {
    font-size: 1.3em;
    color: var(--text);
    margin-bottom: 20px;
    font-weight: 600;
  }

  .disclaimer {
    text-align: center;
    color: var(--muted);
    font-size: 12px;
    margin-bottom: 24px;
    padding: 8px 16px;
    border: var(--border);
    border-radius: 8px;
    background: var(--surface-subtle);
  }

  .member-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 14px;
  }

  .member-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    background: var(--card);
    border: var(--border);
    border-radius: 14px;
    padding: 44px 12px 20px;
    transition: all .25s ease;
  }

  .member-card:hover {
    background: var(--surface-subtle);
    transform: translateY(-3px);
  }

  .avatar {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-on-brand);
    font-weight: 700;
    font-size: 32px;
    margin-bottom: 14px;
    object-fit: cover;
  }

  img.avatar { object-fit: cover; }

  .avatar-frame {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 14px;
    position: relative;
    background: linear-gradient(135deg, var(--brand), var(--brand2), var(--success), var(--brand));
    background-size: 300% 300%;
    animation: frameGlow 3s ease-in-out infinite;
    padding: 3px;
  }

  .avatar-frame .avatar {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    margin-bottom: 0;
  }

  .avatar-frame--overlay {
    background: none;
    animation: none;
    padding: 0;
  }

  .avatar-frame-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    -webkit-user-drag: none;
    user-select: none;
    -webkit-user-select: none;
    border-radius: 50%;
    object-fit: contain;
    transform: scale(1.7);
  }

  @keyframes frameGlow {
    0%, 100% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
  }

  .card-rogers {
    position: relative;
    overflow: hidden;
    transform-style: preserve-3d;
    --shine-x: 50%;
    --shine-y: 50%;
  }

  .card-rogers .avatar {
    position: relative;
    z-index: 2;
    border-radius: 50%;
    object-fit: cover;
    will-change: transform;
  }

  .card-rogers .shine {
    position: absolute;
    z-index: 3;
    inset: 0;
    border-radius: 14px;
    pointer-events: none;
    background: radial-gradient(circle at var(--shine-x) var(--shine-y), rgba(255,255,255,.4) 0%, rgba(255,255,255,.05) 40%, transparent 70%);
    mix-blend-mode: overlay;
    opacity: 0;
    transition: opacity .4s ease;
  }

  .card-rogers:hover .shine {
    opacity: 1;
  }

  .card-rogers::before {
    content: "";
    position: absolute;
    z-index: 1;
    top: 38px;
    left: 50%;
    width: 100px;
    height: 100px;
    border-radius: 50%;
    padding: 6px;
    background: conic-gradient(from 0deg, #ff4fd8, #7c5cff, #38d5ff, #46ff9a, #ffe45c, #ff7a45, #ff4fd8);
    -webkit-mask: radial-gradient(farthest-side, transparent calc(100% - 6px), #000 calc(100% - 5px));
    mask: radial-gradient(farthest-side, transparent calc(100% - 6px), #000 calc(100% - 5px));
    animation: rogersRingSpin 2s linear infinite;
    pointer-events: none;
  }

  @keyframes rogersRingSpin {
    0% { transform: translateX(-50%) rotate(0deg); }
    100% { transform: translateX(-50%) rotate(360deg); }
  }

  .card-rogers .glint {
    position: absolute;
    top: 0;
    left: -100%;
    width: 80%;
    height: 100%;
    z-index: 2;
    pointer-events: none;
    background: linear-gradient(115deg, transparent 20%, rgba(255,255,255,.7) 48%, rgba(255,255,255,.9) 50%, rgba(255,255,255,.7) 52%, transparent 80%);
    opacity: 0;
  }

  .card-rogers:hover .glint {
    animation: rogersGlint .7s ease-in-out forwards;
  }

  @keyframes rogersGlint {
    0% { left: -100%; opacity: 0; }
    20% { opacity: .7; }
    60% { opacity: .7; }
    100% { left: 200%; opacity: 0; }
  }

  .rogers-name {
    background: linear-gradient(135deg, var(--brand), var(--brand2));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .card-rogers:hover .rogers-name {
    background: linear-gradient(135deg, #ff4466, #44aaff, #44ff88);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: rogersNameGlow 2s linear infinite;
  }

  @keyframes rogersNameGlow {
    0% { filter: hue-rotate(0deg); }
    100% { filter: hue-rotate(360deg); }
  }

  .rogers-role {
    background: linear-gradient(135deg, var(--brand), var(--brand2));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    font-weight: 600;
  }

  .name {
    color: var(--text);
    font-weight: 600;
    font-size: 15px;
  }

  .role {
    color: var(--muted);
    font-size: 12px;
    line-height: 1.2;
  }

  .footer-text {
    position: relative;
    z-index: 1;
    color: var(--muted);
    font-size: 12px;
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: center;
    opacity: .6;
    margin-top: 36px;
  }

  .footer-text .sep { opacity: .4; }
  .footer-text a { color: var(--muted); transition: color .2s; }
  .footer-text a:hover { color: var(--text); text-decoration: none; }

  .vieilami-author-avatar-link {
    display: inline-block;
    text-decoration: none;
  }

  .vieilami-author-avatar-frame {
    position: relative;
    width: 100px;
    height: 100px;
    margin: 0 auto 14px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    cursor: pointer;
    transition: .45s ease;
  }

  .vieilami-author-avatar-frame::before,
  .vieilami-author-avatar-frame::after {
    content: "";
    position: absolute;
    border-radius: inherit;
    transition: .45s ease;
  }

  .vieilami-author-avatar-frame::before {
    inset: -5px;
    background: conic-gradient(from 0deg, #ff4fd8, #7c5cff, #38d5ff, #46ff9a, #ffe45c, #ff7a45, #ff4fd8);
    animation: vieilamiRotate 3.2s linear infinite;
    box-shadow: 0 0 12px rgba(124, 92, 255, .45), 0 0 22px rgba(56, 213, 255, .25);
    z-index: 0;
  }

  .vieilami-author-avatar-frame::after {
    inset: -12px;
    background: conic-gradient(#ff4fd8, #38d5ff, #46ff9a, #ffe45c, #ff4fd8);
    filter: blur(18px);
    opacity: .28;
    animation: vieilamiRotate 5s linear infinite;
    z-index: -1;
  }

  .vieilami-author-avatar-inner {
    position: relative;
    width: 100%;
    height: 100%;
    padding: 5px;
    border-radius: 50%;
    background: linear-gradient(145deg, #fff, #9aa7ff 45%, #2b2f55);
    box-shadow: inset 0 3px 5px rgba(255,255,255,.85), inset 0 -6px 10px rgba(0,0,0,.35), 0 8px 18px rgba(0,0,0,.45);
    box-sizing: border-box;
    z-index: 1;
    transition: .45s ease;
  }

  :root.dark .vieilami-author-avatar-inner {
    background: linear-gradient(145deg, #eef, #9aa7ff 45%, #1a1d35);
  }

  .vieilami-author-avatar {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    border-radius: 50%;
    border: 3px solid rgba(255,255,255,.9);
    box-sizing: border-box;
    transition: .45s ease;
  }

  .member-card:hover .vieilami-author-avatar-frame {
    transform: scale(1.05);
    border-radius: 24px;
  }

  .member-card:hover .vieilami-author-avatar-frame::before {
    inset: -4px;
    border-radius: 28px;
    animation: none;
    background: linear-gradient(145deg, #fff6d8, #ffd76a 20%, #c89d2b, #ffe89c 70%, #8d6515);
    box-shadow: 0 0 10px rgba(255, 215, 100, .35), 0 0 25px rgba(255, 200, 80, .15), inset 0 1px 2px rgba(255,255,255,.8), inset 0 -3px 6px rgba(0,0,0,.35);
  }

  .member-card:hover .vieilami-author-avatar-frame::after {
    border-radius: 30px;
    animation: none;
    background: rgba(255, 215, 120, .9);
    opacity: .12;
    filter: blur(14px);
  }

  .member-card:hover .vieilami-author-avatar-inner {
    border-radius: 24px;
    background: linear-gradient(145deg, #fff9e8, #ffd76d 35%, #b78412 65%, #5f4306);
    box-shadow: inset 0 2px 3px rgba(255,255,255,.9), inset 0 -4px 6px rgba(0,0,0,.35), 0 10px 24px rgba(0,0,0,.45);
  }

  .member-card:hover .vieilami-author-avatar {
    border-radius: 20px;
    border-color: rgba(255,255,255,.92);
    transform: scale(.985);
  }

  .vieilami-author-name {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    font-size: 15px;
    font-weight: 700;
  }

  .vieilami-author-badge {
    position: relative;
    width: 22px;
    height: 22px;
    display: inline-grid;
    place-items: center;
    border-radius: 50%;
    overflow: hidden;
    background: linear-gradient(145deg, #fff9df, #ffd65a, #b77c07);
    box-shadow: inset 0 1px 1px rgba(255,255,255,.85), inset 0 -1px 2px rgba(0,0,0,.25);
    transform: scale(.92);
    transition: .45s ease;
  }

  .vieilami-author-badge::after {
    content: "";
    position: absolute;
    top: -50%;
    left: -200%;
    width: 60%;
    height: 220%;
    transform: rotate(25deg);
    background: linear-gradient(90deg, transparent, rgba(255,255,255,.9), transparent);
    opacity: 0;
    pointer-events: none;
  }

  .vieilami-author-badge-icon {
    position: relative;
    z-index: 2;
    font-size: 12px;
    line-height: 1;
  }

  .member-card:hover .vieilami-author-badge {
    transform: scale(1);
    box-shadow: inset 0 1px 1px rgba(255,255,255,.9), inset 0 -1px 2px rgba(0,0,0,.25), 0 2px 8px rgba(255,200,80,.18);
  }

  .member-card:hover .vieilami-author-badge::after {
    animation: vieilamiBadgeSweep .8s ease-out forwards;
  }

  .vieilami-author-name-text {
    background: linear-gradient(145deg, var(--text), var(--muted));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    transition: .45s ease;
  }

  .member-card:hover .vieilami-author-name-text {
    background: linear-gradient(115deg, #fff8d8, #ffd84d 22%, #b97808 40%, #fff7be, #c58a12 60%, #ffd84d 78%, #fff8d8);
    background-size: 300% 100%;
    background-position: 180% 0;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: vieilamiTextShine 1s ease-out forwards;
  }

  .vieilami-author-role {
    color: var(--muted);
    font-size: 12px;
    line-height: 1.2;
  }

  @keyframes vieilamiRotate {
    to { transform: rotate(360deg); }
  }

  @keyframes vieilamiBadgeSweep {
    0% { left: -200%; opacity: 0; }
    15% { opacity: 1; }
    85% { opacity: 1; }
    100% { left: 300%; opacity: 0; }
  }

  @keyframes vieilamiTextShine {
    0% { background-position: 180% 0; }
    100% { background-position: -180% 0; }
  }

  @media (max-width: 640px) {
    .page-title { font-size: 1.8em; }
    .member-card { padding: 12px 16px; }
  }
</style>

<script>
  (function() {
    var card = document.querySelector('.card-rogers');
    if (!card) return;

    var tilt = { x: 0, y: 0 };
    var target = { x: 0, y: 0 };
    var velocity = { x: 0, y: 0 };
    var pointer = { x: 50, y: 50 };
    var targetPointer = { x: 50, y: 50 };
    var pointerVelocity = { x: 0, y: 0 };
    var stiffness = 0.08;
    var damping = 0.28;
    var frameId = null;

    card.addEventListener('pointermove', function(e) {
      var rect = card.getBoundingClientRect();
      var px = ((e.clientX - rect.left) / rect.width) * 100;
      var py = ((e.clientY - rect.top) / rect.height) * 100;
      targetPointer.x = Math.min(Math.max(px, 0), 100);
      targetPointer.y = Math.min(Math.max(py, 0), 100);
      var cx = rect.left + rect.width / 2;
      var cy = rect.top + rect.height / 2;
      target.x = ((e.clientX - cx) / (rect.width / 2)) * 18;
      target.y = -((e.clientY - cy) / (rect.height / 2)) * 18;
      if (!frameId) frameId = requestAnimationFrame(step);
    });

    card.addEventListener('pointerleave', function() {
      target.x = 0;
      target.y = 0;
      targetPointer.x = 50;
      targetPointer.y = 50;
      if (!frameId) frameId = requestAnimationFrame(step);
    });

    function step() {
      var dx = target.x - tilt.x;
      var dy = target.y - tilt.y;
      velocity.x += dx * stiffness;
      velocity.y += dy * stiffness;
      velocity.x *= 1 - damping;
      velocity.y *= 1 - damping;
      tilt.x += velocity.x;
      tilt.y += velocity.y;

      var pdx = targetPointer.x - pointer.x;
      var pdy = targetPointer.y - pointer.y;
      pointerVelocity.x += pdx * 0.06;
      pointerVelocity.y += pdy * 0.06;
      pointerVelocity.x *= 0.72;
      pointerVelocity.y *= 0.72;
      pointer.x += pointerVelocity.x;
      pointer.y += pointerVelocity.y;

      card.style.transform = 'perspective(400px) rotateY(' + tilt.x.toFixed(2) + 'deg) rotateX(' + tilt.y.toFixed(2) + 'deg)';
      card.style.setProperty('--shine-x', pointer.x.toFixed(1) + '%');
      card.style.setProperty('--shine-y', pointer.y.toFixed(1) + '%');

      if (Math.abs(dx) > 0.01 || Math.abs(dy) > 0.01 || Math.abs(velocity.x) > 0.01 || Math.abs(velocity.y) > 0.01 ||
          Math.abs(pdx) > 0.1 || Math.abs(pdy) > 0.1) {
        frameId = requestAnimationFrame(step);
      } else {
        frameId = null;
      }
    }
  })();
</script>
