<style>
  .page {
    min-height: 100vh;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 40px 20px 80px;
  }

  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
  }

  .orb-1 {
    width: 400px;
    height: 400px;
    background: rgba(255, 105, 180, .1);
    top: -10%;
    right: -10%;
  }

  .orb-2 {
    width: 350px;
    height: 350px;
    background: rgba(91, 124, 255, .08);
    bottom: -10%;
    left: -10%;
  }

  .grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, .015) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, .015) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
  }

  .page-content {
    position: relative;
    z-index: 1;
    max-width: 800px;
    width: 100%;
    animation: fadeUp .8s ease-out;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: rgba(255, 255, 255, .4);
    font-size: 14px;
    margin-bottom: 30px;
    transition: color .2s;
  }

  .back-link:hover {
    color: rgba(255, 255, 255, .7);
    text-decoration: none;
  }

  .page-title {
    font-size: 2.5em;
    font-weight: 800;
    background: linear-gradient(135deg, #ff69b4, #5b7cff);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 4px;
  }

  .page-subtitle {
    color: rgba(255, 255, 255, .4);
    font-size: 14px;
    letter-spacing: 3px;
    margin-bottom: 30px;
  }

  .intro {
    background: rgba(255, 255, 255, .03);
    border: 1px solid rgba(255, 255, 255, .06);
    border-radius: 16px;
    padding: 20px 24px;
    margin-bottom: 40px;
  }

  .intro p {
    color: rgba(255, 255, 255, .55);
    font-size: 15px;
    line-height: 1.8;
    margin: 6px 0;
  }

  .section-title {
    font-size: 1.3em;
    color: rgba(255, 255, 255, .7);
    margin-bottom: 20px;
    font-weight: 600;
  }

  .disclaimer {
    text-align: center;
    color: rgba(255, 255, 255, .25);
    font-size: 12px;
    margin-bottom: 24px;
    padding: 8px 16px;
    border: 1px solid rgba(255, 255, 255, .06);
    border-radius: 8px;
    background: rgba(255, 255, 255, .02);
  }

  .member-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 14px;
  }

  .member-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    background: rgba(255, 255, 255, .03);
    border: 1px solid rgba(255, 255, 255, .06);
    border-radius: 14px;
    padding: 28px 12px 20px;
    transition: all .25s ease;
  }

  .member-card:hover {
    background: rgba(255, 255, 255, .06);
    transform: translateY(-3px);
  }

  .avatar {
    width: 100px;
    height: 100px;
    border-radius: 20px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-weight: 700;
    font-size: 32px;
    margin-bottom: 14px;
  }

  img.avatar {
    object-fit: cover;
  }

  .avatar-frame {
    width: 100px;
    height: 100px;
    border-radius: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 14px;
    position: relative;
    background: linear-gradient(135deg, #ff69b4, #5b7cff, #00c853, #ff69b4);
    background-size: 300% 300%;
    animation: frameGlow 3s ease-in-out infinite;
    padding: 3px;
  }

  .avatar-frame .avatar {
    width: 100%;
    height: 100%;
    border-radius: 20px;
    margin-bottom: 0;
  }

  @keyframes frameGlow {
    0%,
    100% {
      background-position: 0% 50%;
      filter: brightness(1);
      box-shadow: 0 0 20px rgba(255, 105, 180, .3);
    }

    50% {
      background-position: 100% 50%;
      filter: brightness(1.2);
      box-shadow: 0 0 40px rgba(91, 124, 255, .5);
    }
  }

  .name {
    color: rgba(255, 255, 255, .85);
    font-weight: 600;
    font-size: 15px;
    margin-bottom: 0;
  }

  .role {
    color: rgba(255, 255, 255, .35);
    font-size: 12px;
    margin-top: 0;
    line-height: 1.2;
  }

  .footer-text {
    position: absolute;
    bottom: 24px;
    z-index: 1;
    color: rgba(255, 255, 255, .2);
    font-size: 12px;
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .footer-text .sep {
    color: rgba(255, 255, 255, .1);
  }

  .footer-text a {
    color: rgba(255, 255, 255, .3);
    transition: color .2s;
  }

  .footer-text a:hover {
    color: rgba(255, 255, 255, .6);
    text-decoration: none;
  }

  .vieilami-author-avatar-link {
    display: inline-block;
    text-decoration: none;
  }

  .vieilami-author-avatar-frame {
    position: relative;
    width: 100px;
    height: 100px;
    margin: 0 auto 14px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    cursor: pointer;
    transition: .45s ease;
  }

  .vieilami-author-avatar-frame::before,
  .vieilami-author-avatar-frame::after {
    content: "";
    position: absolute;
    border-radius: inherit;
    transition: .45s ease;
  }

  .vieilami-author-avatar-frame::before {
    inset: -5px;
    background: conic-gradient(
      from 0deg,
      #ff4fd8,
      #7c5cff,
      #38d5ff,
      #46ff9a,
      #ffe45c,
      #ff7a45,
      #ff4fd8
    );
    animation: vieilamiAuthorRotateLight 3.2s linear infinite;
    box-shadow:
      0 0 12px rgba(124, 92, 255, .45),
      0 0 22px rgba(56, 213, 255, .25);
    z-index: 0;
  }

  .vieilami-author-avatar-frame::after {
    inset: -12px;
    background: conic-gradient(
      #ff4fd8,
      #38d5ff,
      #46ff9a,
      #ffe45c,
      #ff4fd8
    );
    filter: blur(18px);
    opacity: .28;
    animation: vieilamiAuthorRotateLight 5s linear infinite;
    z-index: -1;
  }

  .vieilami-author-avatar-inner {
    position: relative;
    width: 100%;
    height: 100%;
    padding: 5px;
    border-radius: 50%;
    background: linear-gradient(145deg, #ffffff, #9aa7ff 45%, #2b2f55);
    box-shadow:
      inset 0 3px 5px rgba(255, 255, 255, .85),
      inset 0 -6px 10px rgba(0, 0, 0, .35),
      0 8px 18px rgba(0, 0, 0, .45);
    box-sizing: border-box;
    z-index: 1;
    transition: .45s ease;
  }

  .vieilami-author-avatar {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    border-radius: 50%;
    border: 3px solid rgba(255, 255, 255, .9);
    box-sizing: border-box;
    transition: .45s ease;
  }

  .member-card:hover .vieilami-author-avatar-frame {
    transform: scale(1.05);
    border-radius: 24px;
  }

  .member-card:hover .vieilami-author-avatar-frame::before {
    inset: -4px;
    border-radius: 28px;
    animation: none;
    background: linear-gradient(
      145deg,
      #fff6d8 0%,
      #ffd76a 20%,
      #c89d2b 45%,
      #ffe89c 70%,
      #8d6515 100%
    );
    box-shadow:
      0 0 10px rgba(255, 215, 100, .35),
      0 0 25px rgba(255, 200, 80, .15),
      inset 0 1px 2px rgba(255, 255, 255, .8),
      inset 0 -3px 6px rgba(0, 0, 0, .35);
  }

  .member-card:hover .vieilami-author-avatar-frame::after {
    border-radius: 30px;
    animation: none;
    background: rgba(255, 215, 120, .9);
    opacity: .12;
    filter: blur(14px);
  }

  .member-card:hover .vieilami-author-avatar-inner {
    border-radius: 24px;
    background: linear-gradient(
      145deg,
      #fff9e8,
      #ffd76d 35%,
      #b78412 65%,
      #5f4306
    );
    box-shadow:
      inset 0 2px 3px rgba(255, 255, 255, .9),
      inset 0 -4px 6px rgba(0, 0, 0, .35),
      0 10px 24px rgba(0, 0, 0, .45);
  }

  .member-card:hover .vieilami-author-avatar {
    border-radius: 20px;
    border-color: rgba(255, 255, 255, .92);
    transform: scale(.985);
  }

  .vieilami-author-name {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    margin-top: 0;
    font-size: 15px;
    font-weight: 700;
    text-shadow: 0 2px 8px rgba(0, 0, 0, .45);
  }

  .vieilami-author-badge {
    position: relative;
    width: 22px;
    height: 22px;
    display: inline-grid;
    place-items: center;
    border-radius: 50%;
    overflow: hidden;
    background: linear-gradient(145deg, #fff9df, #ffd65a, #b77c07);
    box-shadow:
      inset 0 1px 1px rgba(255, 255, 255, .85),
      inset 0 -1px 2px rgba(0, 0, 0, .25);
    transform: scale(.92);
    transition: .45s ease;
  }

  .vieilami-author-badge::after {
    content: "";
    position: absolute;
    top: -50%;
    left: -200%;
    width: 60%;
    height: 220%;
    transform: rotate(25deg);
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, .9),
      transparent
    );
    opacity: 0;
    pointer-events: none;
  }

  .vieilami-author-badge-icon {
    position: relative;
    z-index: 2;
    font-size: 12px;
    line-height: 1;
  }

  .member-card:hover .vieilami-author-badge {
    transform: scale(1);
    box-shadow:
      inset 0 1px 1px rgba(255, 255, 255, .9),
      inset 0 -1px 2px rgba(0, 0, 0, .25),
      0 2px 8px rgba(255, 200, 80, .18);
  }

  .member-card:hover .vieilami-author-badge::after {
    animation: vieilamiAuthorBadgeSweep .8s ease-out forwards;
  }

  .vieilami-author-name-text {
    background: linear-gradient(145deg, #ffffff, #f0f0f0);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    transition: .45s ease;
  }

  .member-card:hover .vieilami-author-name-text {
    background: linear-gradient(
      115deg,
      #fff8d8 0%,
      #ffd84d 22%,
      #b97808 40%,
      #fff7be 50%,
      #c58a12 60%,
      #ffd84d 78%,
      #fff8d8 100%
    );
    background-size: 300% 100%;
    background-position: 180% 0;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: vieilamiAuthorTextShine 1s ease-out forwards;
  }

  .vieilami-author-role {
    color: rgba(255, 255, 255, .35);
    font-size: 12px;
    margin-top: 0;
    line-height: 1.2;
  }

  @keyframes vieilamiAuthorRotateLight {
    to {
      transform: rotate(360deg);
    }
  }

  @keyframes vieilamiAuthorBadgeSweep {
    0% {
      left: -200%;
      opacity: 0;
    }

    15% {
      opacity: 1;
    }

    85% {
      opacity: 1;
    }

    100% {
      left: 300%;
      opacity: 0;
    }
  }

  @keyframes vieilamiAuthorTextShine {
    0% {
      background-position: 180% 0;
      filter: brightness(1);
