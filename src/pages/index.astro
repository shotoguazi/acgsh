---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout>
  <section class="hero">
    <div class="hero-content">
      <h1 class="hero-title">魔都ACGN活动交流群-资讯站</h1>
      <p class="hero-subtitle">Shanghai Anime Docs</p>
      <p class="hero-tagline">这是一个隶属于 acgsh 的非营利性资讯站</p>
      <div class="hero-actions">
        <a href="/guide/exhibit/BilibiliWorldBasicInfo/" class="btn btn-brand">BW2027</a>
        <a href="/guide/concert/BilibiliMacroLinkBasicInfo/" class="btn btn-brand">BML2027</a>
        <a href="/guide/exhibit/ChinaJoyBasicInfo/" class="btn btn-brand">ChinaJoy</a>
        <a href="/guide/intro/BilibiliMacroLinkIntro/" class="btn btn-brand">关于BML</a>
        <a href="/guide/others/ShanghaiTravelGuide_Anime/" class="btn btn-brand">上海游物推荐</a>
      </div>
      <span class="btn btn-alt">陆续增加中...</span>
    </div>
    <div class="hero-image">
      <article class="main-card">
        <span class="deco orb-a" aria-hidden="true"></span>
        <span class="deco orb-b" aria-hidden="true"></span>
        <span class="deco tile-a" aria-hidden="true"></span>
        <span class="deco tile-b" aria-hidden="true"></span>
        <div class="main-content">
          <div class="topline">
            <span class="logo">哔哩哔哩 (゜-゜)つロ 干杯~</span>
            <p class="target-time" id="mainTargetTime">2027.07.09</p>
          </div>
          <h1 id="mainTitle">BILIBILI 2027</h1>
          <p class="event-note" id="mainNote"></p>
          <div class="primary-countdown" id="primaryCountdown" aria-live="polite">
            <div class="time-cell main">
              <span class="num" id="mainDays">00</span>
              <span class="label">天</span>
            </div>
            <div class="time-cell">
              <span class="num" id="mainHours">00</span>
              <span class="label">时</span>
            </div>
            <div class="time-cell">
              <span class="num" id="mainMinutes">00</span>
              <span class="label">分</span>
            </div>
            <div class="time-cell">
              <span class="num" id="mainSeconds">00</span>
              <span class="label">秒</span>
            </div>
          </div>
        </div>
      </article>
    </div>
  </section>

  <section class="features">
    <div class="feature-card warn">
      <h2>警告⚠️</h2>
      <p>未经证实的消息不要转发。但是各位还是请注意安全。不接受陌生人食物！</p>
    </div>
    <div class="feature-card">
      <h2>本站建立的目的性</h2>
      <p>汇聚全网 ACGN 活动资源，打造魔都最全的 ACGN 活动信息平台！</p>
    </div>
    <div class="feature-card">
      <h2>精准定位，快速查找</h2>
      <p>通过便捷的筛选功能，快速找到你心仪的活动，不再错过任何精彩瞬间！</p>
    </div>
    <div class="feature-card">
      <h2>实时更新，一手掌握</h2>
      <p>一手资源，实时更新活动信息，让你永远快人一步！</p>
    </div>
  </section>
</BaseLayout>

<script>
  const mainEvent = {
    title: "哔哩哔哩乐园2027 还剩",
    note: "Bilibili World 2027 预估倒计时",
    time: "2027-07-09T08:30:00+08:00"
  };

  const particleColors = [
    { fill: "rgba(122, 224, 240, 0.78)", glow: "rgba(122, 224, 240, 0.42)" },
    { fill: "rgba(255, 156, 207, 0.72)", glow: "rgba(255, 156, 207, 0.36)" },
    { fill: "rgba(255, 255, 255, 0.72)", glow: "rgba(160, 229, 241, 0.32)" }
  ];

  const PARTICLES_PER_CELL = 40;

  const DOM = {
    primaryCountdown: document.querySelector("#primaryCountdown"),
    mainTitle: document.querySelector("#mainTitle"),
    mainNote: document.querySelector("#mainNote"),
    mainTargetTime: document.querySelector("#mainTargetTime"),
    mainDays: document.querySelector("#mainDays"),
    mainHours: document.querySelector("#mainHours"),
    mainMinutes: document.querySelector("#mainMinutes"),
    mainSeconds: document.querySelector("#mainSeconds"),
  };

  let lastMinute = null;

  const pad = (value) => String(value).padStart(2, "0");

  function getParts(timeString) {
    const remaining = Math.max(0, new Date(timeString).getTime() - Date.now());
    const totalSeconds = Math.floor(remaining / 1000);
    return {
      days: Math.floor(totalSeconds / 86400),
      hours: Math.floor((totalSeconds % 86400) / 3600),
      minutes: Math.floor((totalSeconds % 3600) / 60),
      seconds: totalSeconds % 60
    };
  }

  function formatTargetTime(timeString) {
    const date = new Date(timeString);
    return `${date.getFullYear()}.${pad(date.getMonth() + 1)}.${pad(date.getDate())} ${pad(date.getHours())}:${pad(date.getMinutes())}`;
  }

  function setupPage() {
    DOM.mainTitle.textContent = mainEvent.title;
    DOM.mainNote.textContent = mainEvent.note;
    DOM.mainTargetTime.textContent = formatTargetTime(mainEvent.time);
  }

  function renderMain() {
    const parts = getParts(mainEvent.time);
    DOM.mainDays.textContent = pad(parts.days);
    DOM.mainHours.textContent = pad(parts.hours);
    DOM.mainMinutes.textContent = pad(parts.minutes);
    DOM.mainSeconds.textContent = pad(parts.seconds);

    if (lastMinute !== null && parts.minutes !== lastMinute) {
      playMinuteEffect();
    }
    lastMinute = parts.minutes;
  }

  function renderAll() {
    renderMain();
  }

  function playMinuteEffect() {
    [...DOM.primaryCountdown.querySelectorAll(".time-cell")].forEach((cell) => {

      cell.classList.remove("refresh");
      cell.querySelectorAll(".cell-particle").forEach(p => p.remove());
      void cell.offsetWidth;
      cell.classList.add("refresh");

      createCellParticles(cell);
    });
  }

  function createCellParticles(cell) {
    const fragment = document.createDocumentFragment();

    for (let i = 0; i < PARTICLES_PER_CELL; i += 1) {
      const particle = document.createElement("span");
      const color = particleColors[i % particleColors.length];

      const size = 1.5 + Math.random() * 2.6;
      const drift = (Math.random() - 0.5) * 26;
      const rise = -(46 + Math.random() * 54);
      const peakOpacity = 0.38 + Math.random() * 0.42;

      particle.className = "cell-particle";
      particle.style.setProperty("--left", `${6 + Math.random() * 88}%`);
      particle.style.setProperty("--bottom", `${-9 + Math.random() * 16}px`);
      particle.style.setProperty("--size", `${size}px`);
      particle.style.setProperty("--drift", `${drift}px`);
      particle.style.setProperty("--rise", `${rise}px`);
      particle.style.setProperty("--duration", `${2300 + Math.random() * 520}ms`);
      particle.style.setProperty("--delay", `${Math.random() * 180}ms`);
      particle.style.setProperty("--end-scale", `${0.72 + Math.random() * 0.58}`);
      particle.style.setProperty("--peak-opacity", `${peakOpacity}`);
      particle.style.setProperty("--tail-opacity", `${peakOpacity * 0.62}`);
      particle.style.setProperty("--particle-color", color.fill);
      particle.style.setProperty("--particle-glow", color.glow);

      particle.addEventListener("animationend", () => particle.remove(), { once: true });
      fragment.appendChild(particle);
    }

    cell.appendChild(fragment);
  }

  setupPage();
  renderAll();
  setInterval(renderAll, 1000);
  window.addEventListener("load", () => setTimeout(playMinuteEffect, 500));
</script>

<style>
  .hero {
    max-width: 1400px;
    margin: 0 auto;
    padding: 60px 20px;
    display: flex;
    align-items: center;
    gap: 40px;
  }

  .hero-content {
    flex: 1;
  }

  .hero-title {
    font-size: 3.2em;
    background: linear-gradient(135deg, var(--brand), var(--brand2));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 2px;
  }

  .hero-subtitle {
    font-size: 2.2em;
    font-weight: 700;
    color: var(--muted);
    margin-bottom: 2px;
  }

  .hero-tagline {
    font-size: 1.05em;
    color: var(--muted);
    margin-bottom: 32px;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .btn {
    display: inline-block;
    padding: 10px 20px;
    border-radius: 999px;
    font-size: 14px;
    font-weight: 600;
    transition: all .2s;
    cursor: pointer;
  }

  .btn-brand {
    background: transparent;
    border: 1.5px solid rgba(var(--brand2-rgb), .3);
    color: var(--brand2);
  }

  .btn-brand:hover {
    background: rgba(var(--brand2-rgb), .08);
    border-color: var(--brand2);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .btn-alt {
    background: transparent;
    border: 2px dashed var(--border);
    color: var(--muted);
    margin-top: 8px;
  }

  .hero-image {
    flex-shrink: 0;
    width: 480px;
    container-type: inline-size;
  }

  .features {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px 60px;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 16px;
  }

  .feature-card {
    background: var(--card);
    border: var(--border);
    border-radius: var(--radius);
    padding: var(--pad);
    box-shadow: var(--shadow);
    min-height: 150px;
  }

  .feature-card.warn {
    border-left: 4px solid var(--danger);
    background: linear-gradient(135deg, rgba(var(--danger-rgb), .05), transparent);
  }

  .feature-card h2 {
    font-size: var(--h2);
    margin-bottom: 10px;
    color: var(--text);
  }

  .feature-card p {
    color: var(--muted);
    font-size: var(--base);
    line-height: 1.7;
  }

  .main-card {
    position: relative;
    min-height: 57cqi;
    padding: 5.7cqi 5.2cqi 4.8cqi;
    border-radius: 5.7cqi;
    overflow: hidden;
    border: 1px solid var(--glass-card-border);
    background: var(--glass-card-bg);
    box-shadow: var(--shadow-card);
    backdrop-filter: blur(18px) saturate(128%);
  }

  .main-card .deco {
    position: absolute;
    z-index: 1;
    pointer-events: none;
    opacity: 0.78;
  }

  .main-card .orb-a {
    left: -46px;
    top: -42px;
    width: 164px;
    aspect-ratio: 1;
    border-radius: 50%;
    background: var(--glass-orb-a);
    animation: driftOrbA 9s ease-in-out infinite;
  }

  .main-card .orb-b {
    right: -54px;
    bottom: -62px;
    width: 172px;
    aspect-ratio: 1;
    border-radius: 50%;
    background: var(--glass-orb-b);
    animation: driftOrbB 10s ease-in-out infinite;
  }

  .main-card .tile-a, .main-card .tile-b {
    border-radius: 12px;
    background: var(--glass-tile-a-bg);
    border: 1px solid var(--glass-card-border);
    backdrop-filter: blur(6px);
  }

  .main-card .tile-a {
    right: 26px;
    top: 58px;
    width: 28px;
    height: 28px;
    transform: rotate(14deg);
    animation: driftTileA 8s ease-in-out infinite;
  }

  .main-card .tile-b {
    left: 32px;
    bottom: 26px;
    width: 20px;
    height: 20px;
    transform: rotate(-18deg);
    background: var(--glass-tile-b-bg);
    animation: driftTileB 7.4s ease-in-out infinite;
  }

  .main-content {
    position: relative;
    z-index: 2;
  }

  .topline {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2.86cqi;
  }

  .logo {
    display: inline-grid;
    place-items: center;
    min-width: 14.8cqi;
    height: 6.7cqi;
    padding: 0 2.4cqi;
    border-radius: 2.1cqi;
    color: var(--text-on-brand);
    font-size: 3.1cqi;
    font-weight: 800;
    letter-spacing: 0;
    background: var(--bili-blue);
    box-shadow: var(--shadow-bili);
  }

  .target-time {
    margin: 0;
    font-size: 2.86cqi;
    font-weight: 800;
    color: var(--text-countdown-label);
  }

  .main-card h1 {
    margin: 3.3cqi 0 1cqi;
    font-size: 5cqi;
    line-height: 1.22;
    letter-spacing: 0;
    color: var(--text);
  }

  .event-note {
    margin: 0;
    font-size: 2.86cqi;
    line-height: 1.6;
    color: var(--muted);
  }

  .primary-countdown {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1.9cqi;
    margin-top: 4.8cqi;
  }

  .time-cell {
    position: relative;
    min-width: 0;
    overflow: hidden;
    padding: 2.4cqi 1.4cqi 2.1cqi;
    border-radius: 3.3cqi;
    text-align: center;
    background: var(--glass-cell-bg);
    border: 1px solid var(--glass-cell-border);
    box-shadow: inset 0 1px 0 var(--glass-inset-light), inset 0 -1px 0 rgba(var(--bili-blue-rgb), 0.08);
    backdrop-filter: blur(12px) saturate(120%);
  }

  .time-cell.main {
    background: var(--glass-cell-main-bg);
  }

  .time-cell::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0;
    background:
      radial-gradient(circle at 16% 90%, rgba(0, 161, 214, 0.56) 0 1.3px, transparent 2px),
      radial-gradient(circle at 32% 78%, rgba(255, 146, 200, 0.5) 0 1.2px, transparent 2px),
      radial-gradient(circle at 48% 88%, rgba(117, 221, 236, 0.58) 0 1.4px, transparent 2.2px),
      radial-gradient(circle at 64% 73%, rgba(255, 180, 220, 0.5) 0 1.1px, transparent 2px),
      radial-gradient(circle at 78% 84%, rgba(0, 161, 214, 0.48) 0 1.2px, transparent 2px),
      radial-gradient(circle at 88% 94%, rgba(255, 146, 200, 0.42) 0 1px, transparent 1.8px),
      radial-gradient(circle at 26% 62%, rgba(122, 225, 238, 0.42) 0 1px, transparent 1.8px),
      radial-gradient(circle at 58% 58%, rgba(255, 146, 200, 0.38) 0 0.9px, transparent 1.7px),
      linear-gradient(to top, rgba(154, 231, 244, 0.22), rgba(255, 169, 213, 0.16), transparent 78%);
    transform: translateY(42%);
    mask-image: linear-gradient(to top, transparent 0%, #000 16%, #000 76%, transparent 100%);
  }

  .time-cell::after {
    content: "";
    position: absolute;
    left: 8px;
    right: 8px;
    bottom: -16px;
    height: 42px;
    pointer-events: none;
    opacity: 0;
    border-radius: 999px 999px 0 0;
    background: radial-gradient(ellipse at center, rgba(141, 229, 242, 0.36), rgba(255, 170, 216, 0.18) 48%, transparent 72%);
    filter: blur(7px);
    transform: translateY(12px) scaleX(0.82);
  }

  .time-cell.refresh::before {
    animation: ultraSweep 980ms ease-out forwards;
  }

  .time-cell.refresh::after {
    animation: softBase 980ms ease-out forwards;
  }

  .cell-particle {
    position: absolute;
    left: var(--left);
    bottom: var(--bottom);
    z-index: 1;
    width: var(--size);
    height: var(--size);
    border-radius: 999px;
    pointer-events: none;
    opacity: 0;
    background: var(--particle-color);
    box-shadow: 0 0 9px var(--particle-glow);
    transform: translate3d(0, 18px, 0) scale(0.4);
    animation: particleRise var(--duration) cubic-bezier(0.2, 0.7, 0.28, 1) forwards;
    animation-delay: var(--delay);
  }

  .num, .label {
    position: relative;
    z-index: 3;
  }

  .num {
    display: block;
    font-variant-numeric: tabular-nums;
    font-size: 5.7cqi;
    line-height: 1;
    font-weight: 900;
    color: var(--text-countdown);
    font-family: "Microsoft YaHei UI", "PingFang SC", "Segoe UI", sans-serif;
  }

  .label {
    display: block;
    margin-top: 1.4cqi;
    font-size: 2.6cqi;
    color: var(--text-countdown-label);
    font-family: "Microsoft YaHei UI", "PingFang SC", "Segoe UI", sans-serif;
  }

  @keyframes driftOrbA {
    0%, 100% { transform: translate(0, 0); }
    50%      { transform: translate(11px, 8px); }
  }

  @keyframes driftOrbB {
    0%, 100% { transform: translate(0, 0); }
    50%      { transform: translate(-10px, -9px); }
  }

  @keyframes driftTileA {
    0%, 100% { transform: translate(0, 0) rotate(14deg); }
    50%      { transform: translate(-8px, 9px) rotate(20deg); }
  }

  @keyframes driftTileB {
    0%, 100% { transform: translate(0, 0) rotate(-18deg); }
    50%      { transform: translate(9px, -7px) rotate(-10deg); }
  }

  @keyframes ultraSweep {
    0%   { opacity: 0; transform: translateY(54%) scale(0.94); filter: blur(1.2px); }
    16%  { opacity: 1; filter: blur(0.4px); }
    68%  { opacity: 0.78; }
    100% { opacity: 0; transform: translateY(-66%) scale(1.02); filter: blur(1.1px); }
  }

  @keyframes softBase {
    0%   { opacity: 0; transform: translateY(14px) scaleX(0.76); }
    20%  { opacity: 0.9; }
    72%  { opacity: 0.34; }
    100% { opacity: 0; transform: translateY(-5px) scaleX(1.08); }
  }

  @keyframes particleRise {
    0%   { opacity: 0; transform: translate3d(0, 18px, 0) scale(0.35); filter: blur(0.3px); }
    14%  { opacity: var(--peak-opacity); }
    76%  { opacity: var(--tail-opacity); }
    100% { opacity: 0; transform: translate3d(var(--drift), var(--rise), 0) scale(var(--end-scale)); filter: blur(0.9px); }
  }

  @media (max-width: 768px) {
    .hero {
      flex-direction: column;
      padding: 20px 20px 40px;
      gap: 20px;
      text-align: center;
    }

    .hero-title { display: none; }
    .hero-subtitle { display: none; }

    .hero-tagline {
      margin-bottom: 16px;
      font-weight: 700;
    }

    .hero-actions {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      justify-items: center;
    }

    .hero-actions .btn {
      width: 100%;
      text-align: center;
      padding: 8px 10px;
      font-size: 13px;
    }

    .btn-alt {
      margin-top: 4px;
    }

    .hero-image {
      width: 100%;
      max-width: 480px;
    }

    .main-card h1 {
      font-size: 7cqi;
    }

    .num {
      font-size: 7cqi;
    }
  }
</style>
