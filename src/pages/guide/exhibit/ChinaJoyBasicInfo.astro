---
import GuideLayout from '@/layouts/GuideLayout.astro';
import { BwHero, BwSection, BwBadge, BwCallout, BwBilingual, BwUpdate, BwLatest, BwHistory } from '@/components/bw/index';
---

<GuideLayout title="ChinaJoy 2026 快速指南 - 魔都ACGN资讯站">
  <div class="bw-wrap">
    <BwHero version="v0.1.0 CJ2026">
      <Fragment slot="title">
        <h1>ChinaJoy 2026 新手快速指南</h1>
      </Fragment>
      <Fragment slot="subtitle">
        <span>ChinaJoy 2026 初心者向けクイックガイド</span>
      </Fragment>
    </BwHero>

    <BwSection>
      <h2>1、ChinaJoy是什么？</h2>
      <BwBilingual>
        <Fragment slot="cn">ChinaJoy全称中国国际数码互动娱乐展览会，涵盖游戏、动漫、电竞等多种数字娱乐领域内容。ChinaJoy每年于7月31日左右在上海新国际博览中心举办，为期4天，每年吸引超40万游客、从业者参加，是当今全球数字娱乐领域最具知名度与影响力的年度盛会之一。</Fragment>
      </BwBilingual>
      <BwCallout type="info">
        今年的ChinaJoy将于 <b>7月31日-8月3日</b> 在 <b>上海新国际博览中心</b> 举办。
      </BwCallout>
    </BwSection>

    <BwSection>
      <h2>2、什么时候开票？ </h2>
        <ul>
          <li>ChinaJoy2026的门票还未发售</li>
        </ul>
    </BwSection>

    <BwSection>
      <h2>3、票价多少，有哪几个票种？</h2>

      <BwCallout type="warn">
        <div class="t">⚠️重要提醒</div>
        今年的ChinaJoy<b>尚未开票</b>，以下为2025年ChinaJoy的常规门票参考
      </BwCallout>
      <table class="bw-table">
        <thead>
          <tr><th class="center">票种</th><th class="center">早鸟票价格</th><th class="center">正式售票价格</th></tr>
        </thead>
        <tbody>
          <tr><td class="center"><b>周五普通票</b></td><td class="center">160元</td><td class="center">180元</td></tr>
          <tr><td class="center"><b>周六、周日普通票</b></td><td class="center">170元</td><td class="center">180元</td></tr>
          <tr><td class="center"><b>周一普通票</b></td><td class="center">100元</td><td class="center">110元</td></tr>
          <tr><td class="center"><b>单日VIP票</b></td><td class="center" colspan="2">350元</td></tr>
          <tr><td class="center"><b>四日VIP套票</b></td><td class="center" colspan="2">1180元</td></tr>
        </tbody>
      </table>

      <BwCallout type="warn">
        <div class="t">⚠️重要提醒</div>
          <ul>
            <li>普通票从1号入口厅排队入场，VIP票从4号门快速入场</li>
            <li>VIP观众可以在N2、N4、E5、E7免费存包</li>
            <li>普通票仅限<b>单日单次入场</b>，VIP票可以<b>当日无限次入场</b></li>
          </ul>
      </BwCallout>
    </BwSection>

  </div>
</GuideLayout>

<style>
  .bw-wrap {
    max-width: 1400px;
    margin: 18px auto 60px;
    padding: 0 14px;
    color: var(--text);
    font-size: var(--base);
    line-height: 1.75;
  }

  .bw-table {
    width: 100%;
    table-layout: fixed;
    border-collapse: collapse;
    overflow: hidden;
    border-radius: var(--radius);
    border: var(--border);
    margin-top: 10px;
  }

  .bw-table th, .bw-table td {
    padding: 12px 10px;
    border-bottom: 1px solid var(--line);
    vertical-align: top;
  }

  .bw-table th {
    text-align: left;
    color: var(--muted);
    font-weight: 700;
    background: var(--surface-subtle);
  }

  .bw-table tr:last-child td { border-bottom: 0; }
  .bw-table .center { text-align: center; }

  .row-green { background: var(--table-row-green); }
  .row-yellow { background: var(--table-row-yellow); }
  .row-gray { background: var(--table-row-gray); opacity: .9; }

  .thanks-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 10px;
    margin-top: 10px;
  }

  .thanks-item {
    display: flex;
    justify-content: space-between;
    gap: 14px;
    padding: 12px 14px;
    border-radius: 14px;
    border: var(--border);
    background: var(--surface-subtle);
    transition: all .18s ease;
  }

  .thanks-item:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow2);
  }

  .thanks-name { font-weight: 800; color: var(--text); }
  .thanks-desc { color: var(--muted); white-space: nowrap; }

  .hl { color: var(--brand); font-weight: 900; }
  .u { text-decoration: underline; text-underline-offset: 3px; }

  .bw-figure {
    margin: 12px 0 0;
    border: var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--surface-subtle);
  }

  .bw-figure img { width: 100%; display: block; }

  .bw-figcap {
    padding: 10px 12px;
    font-size: var(--small);
    color: var(--muted);
    border-top: 1px solid var(--line);
  }

  .bw-section p { margin: 8px 0; }
  .bw-section ul, .bw-section ol { margin: 8px 0; padding-left: 20px; }
  .bw-section li { margin: 4px 0; }

  @media (max-width: 520px) {
    .thanks-item { flex-direction: column; }
    .thanks-desc { white-space: normal; }
  }
</style>

