<style>
  .bw-wrap {
    max-width: 1400px;
    margin: 18px auto 60px;
    padding: 0 14px;
    color: var(--text);
    font-size: var(--base);
    line-height: 1.75;
  }

  .bw-table {
    width: 100%;
    table-layout: fixed;
    border-collapse: collapse;
    overflow: hidden;
    border-radius: var(--radius);
    border: var(--border);
    margin-top: 10px;
  }

  .bw-table th, .bw-table td {
    padding: 12px 10px;
    border-bottom: 1px solid var(--line);
    vertical-align: top;
  }

  .bw-table th {
    text-align: left;
    color: var(--muted);
    font-weight: 700;
    background: rgba(0, 0, 0, .02);
  }

  .bw-table tr:last-child td { border-bottom: 0; }
  .bw-table .center { text-align: center; }
  .bw-table a { color: black; }

  .row-green { background: rgba(0, 200, 83, .10); }
  .row-yellow { background: rgba(249, 168, 37, .12); }
  .row-gray { background: rgba(154, 164, 178, .10); opacity: .9; }

  .thanks-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 10px;
    margin-top: 10px;
  }

  .thanks-item {
    display: flex;
    justify-content: space-between;
    gap: 14px;
    padding: 12px 14px;
    border-radius: 14px;
    border: var(--border);
    background: rgba(0, 0, 0, .02);
    transition: all .18s ease;
  }

  .thanks-item:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow2);
  }

  .thanks-name { font-weight: 800; color: var(--text); }
  .thanks-desc { color: var(--muted); white-space: nowrap; }

  .hl { color: var(--brand); font-weight: 900; }
  .u { text-decoration: underline; text-underline-offset: 3px; }

  .bw-figure {
    margin: 12px 0 0;
    border: var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    background: rgba(0,0,0,.02);
  }

  .bw-figure img { width: 100%; display: block; }

  .bw-figcap {
    padding: 10px 12px;
    font-size: var(--small);
    color: var(--muted);
    border-top: 1px solid var(--line);
  }

  .bw-section p { margin: 8px 0; }
  .bw-section ul, .bw-section ol { margin: 8px 0; padding-left: 20px; }
  .bw-section li { margin: 4px 0; }

  @media (max-width: 520px) {
    .thanks-item { flex-direction: column; }
    .thanks-desc { white-space: normal; }
  }
</style>
