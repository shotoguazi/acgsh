<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>404 - 页面跑丢啦</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      display: flex; justify-content: center; align-items: center; min-height: 100vh;
      background: linear-gradient(135deg, #fce4ec, #e8eaf6, #f3e5f5);
      font-family: "Microsoft YaHei", "PingFang SC", -apple-system, sans-serif;
    }
    .container { text-align: center; padding: 40px 20px; max-width: 520px; }
    h1 {
      font-size: 100px; font-weight: 900;
      background: linear-gradient(135deg, #f48fb1, #ce93d8);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
      line-height: 1.1; letter-spacing: 8px;
    }
    p { font-size: 20px; color: #9575cd; margin: 16px 0 28px; font-weight: 500; }
    .meme-box {
      margin: 0 auto 36px; max-width: 400px; border-radius: 24px; overflow: hidden;
      box-shadow: 0 8px 40px rgba(206, 147, 216, 0.3);
    }
    .meme-box img { display: block; width: 100%; height: auto; }
    .btn-home {
      display: inline-block; padding: 16px 56px; font-size: 20px; font-weight: 600;
      background: linear-gradient(135deg, #f48fb1, #ce93d8); color: #fff;
      text-decoration: none; border-radius: 50px;
      box-shadow: 0 4px 20px rgba(206, 147, 216, 0.4);
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .btn-home:hover { transform: translateY(-2px); box-shadow: 0 6px 28px rgba(206, 147, 216, 0.5); }
  </style>
</head>
<body>
  <div class="container">
